# Discord Bot Configuration
# Copy file này thành .env và điền thông tin của bạn

# Discord Bot Token (BẮT BUỘC)
# Lấy từ: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Multi-PC support (OPTIONAL, per-PC)
# Bind this bot process to one or more Discord channels. Only messages and
# slash commands from these channels will be handled on this PC.
# Use when the same DISCORD_BOT_TOKEN is shared across several PCs, each
# managing its own local ROK bot and listening on its own channel.
# Value: channel ID, or comma-separated list of channel IDs.
# Leave empty to listen everywhere (single-PC setup).
# Example: INSTANCE_CHANNEL=123456789012345678
INSTANCE_CHANNEL=

# Bot Settings
DEBUG=True
LOG_LEVEL=INFO
PREFIX=!

# Bot Activity
ACTIVITY_TYPE=playing
ACTIVITY_NAME=Discord Bot

# Embed Settings
EMBED_COLOR=3498db

# Command Settings
COMMAND_COOLDOWN=3
MAX_MESSAGE_LENGTH=2000

# Permissions
GUILD_ONLY=False
DEFAULT_PERMISSIONS=0

# Auto-Update
# prompt = check GitHub on startup, ask user [y/N] (default N)
# off    = skip update check entirely
AUTO_UPDATE=prompt